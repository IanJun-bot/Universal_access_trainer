*.onnx
*.onnx.json

# --- Piper source-repo folder (not needed; pip package is used) ---
piper-master/

# --- Generated / runtime artifacts ---
*.log
eval_results.json
eval_photos/
test_output.wav
_test*
_verify*
_pre.jpg

# --- Editor / OS cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- Local tooling config ---
.claude/

# --- Local-only notes (kept local, not published) ---
*_REPORT.md
