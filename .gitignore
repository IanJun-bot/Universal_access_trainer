# --- Secrets (NEVER commit) ---
.env
.env.local
*.key

# --- Python virtual environment ---
venv/
.venv/
env/

# --- Python caches / build ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Large model assets (downloaded during setup, not versioned) ---
